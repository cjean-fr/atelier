{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["check", "format"],
      "outputs": ["dist/**"]
    },
    "check": {
      "cache": true
    },
    "format": {
      "cache": true
    },
    "publish": {
      "dependsOn": ["test", "build"]
    },
    "test": {
      "cache": true
    }
  }
}
