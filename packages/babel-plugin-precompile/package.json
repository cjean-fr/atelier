{
  "name": "@cjean-fr/babel-plugin-precompile",
  "version": "0.1.0",
  "description": "Babel plugin that precompiles JSX to tagged template literals (Deno-style)",
  "author": "Christophe Jean",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@cjean-fr/precompile-core": "workspace:*",
    "@babel/core": "catalog:",
    "@babel/types": "catalog:"
  },
  "devDependencies": {
    "@cjean-fr/jsx-string": "workspace:*",
    "@babel/plugin-syntax-jsx": "catalog:",
    "@types/babel__core": "catalog:"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  }
}
