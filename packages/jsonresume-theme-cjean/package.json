{
  "name": "jsonresume-theme-cjean",
  "version": "1.2.0",
  "description": "A clean, professional, and print-optimized JSON Resume theme built with Tailwind CSS and TypeScript.",
  "author": "Christophe Jean",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjean-fr/atelier.git",
    "directory": "packages/jsonresume-theme-cjean"
  },
  "keywords": [
    "jsonresume-theme",
    "resume",
    "cv",
    "tailwind",
    "typescript",
    "print-optimized"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@cjean-fr/i18n-tiny": "^1.0.1",
    "@cjean-fr/jsx-string": "^1.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "zod": "^4.3.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "resume:export": "bunx resume-cli export output.html -t .",
    "resume:serve": "bunx resume-cli serve -t ."
  },
  "type": "module"
}
